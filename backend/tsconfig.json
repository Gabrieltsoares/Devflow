{
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "outDir": "./dist",
    "rootDir": "./src",
    /* Environment Settings */
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "types": ["node"],

    /* Other Outputs */
    "sourceMap": true,

    /* Strict Type Checking */
    "strict": true,

    /* Compatibility */
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "prisma.config.ts"]
}